{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-inline-style": "off",
    "no-implicit-button-type": "off",
    "attribute-boolean-style": "off",
    "doctype-html": "error",
    "no-unknown-attributes": "warn",
    "void-style": ["error", { "style": "selfClosing" }],
    "attribute-separator": "error",
    "no-trailing-whitespace": "error",
    "no-duplicate-attributes": "error",
    "no-redundant-roles": "warn",
    "no-dup-id": "error",
    "valid-content-model": "warn",
    "input-missing-label": "warn",
    "element-case": "error",
    "attr-case": "error",
    "close-order": "warn"
  }
}
